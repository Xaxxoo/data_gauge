# ── VTPass (Nigerian data vending) ──────────────────────────
# Get keys at https://vtpass.com/developer
EXPO_PUBLIC_VTPASS_API_KEY=
EXPO_PUBLIC_VTPASS_SECRET_KEY=
EXPO_PUBLIC_VTPASS_PUBLIC_KEY=
# Set to false in production to make real purchases
EXPO_PUBLIC_VTPASS_SANDBOX=true

# ── GoodDollar ───────────────────────────────────────────────
# Celo wallet address that receives G$ payments from users.
# This wallet then triggers VTPass data delivery.
# REQUIRED: must be a valid 42-character Celo address (0x...).
# The app will refuse to process payments if this is missing or set to the zero address.
EXPO_PUBLIC_PLATFORM_WALLET=

# ── Optional ─────────────────────────────────────────────────
# EAS Build project ID (for Expo Application Services)
# EXPO_PROJECT_ID=
